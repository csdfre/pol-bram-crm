# --- Szerver ---
PORT=3000
BASE_URL=https://your-app.onrender.com
SESSION_SECRET=change-this-to-a-long-random-string

# --- Gmail / Google Workspace SMTP küldéshez ---
# Google Fiókban: Biztonság -> Kételemes azonosítás bekapcsolása -> Alkalmazásjelszavak -> generálj egyet "Mail" névvel
GMAIL_USER=ajanlat@pol-bram.hu
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- Belső e-mail címek ---
COLLEAGUE_EMAIL=lengyel.kollegano@pol-bram.pl
ADMIN_NOTIFY_EMAIL=info@pol-bram.hu

# --- Emlékeztető email (ha X napig nincs válasz a kiküldött ajánlatra) ---
REMINDER_AFTER_DAYS=5
# Külső cron-szolgáltatáshoz (pl. cron-job.org) — csak akkor kell, ha a Render "sleep"-elő ingyenes csomagot használtok
CRON_SECRET=valami-hosszu-veletlenszeru-kulcs

# --- Kezdeti admin felhasználó (npm run init-admin szkripthez) ---
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=change-this-password
